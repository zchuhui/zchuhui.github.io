---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '@/utils/url';

interface Props { entry: CollectionEntry<'projects'>; }
const { entry } = Astro.props;
const { title, description, cover, tech, repo, demo, featured } = entry.data;
const href = withBase(`/projects/${entry.id}`);
---

<article class="card proj">
  <a href={href} class="proj-cover">
    {cover ? (
      <img src={withBase(cover)} alt={title} loading="lazy" />
    ) : (
      <div class="proj-cover-fallback"><span>{title.slice(0, 2)}</span></div>
    )}
    {featured && <span class="proj-badge">精选</span>}
  </a>
  <div class="proj-body">
    <h3 class="proj-title"><a href={href}>{title}</a></h3>
    <p class="proj-desc">{description}</p>
    <div class="proj-tech">
      {tech.slice(0, 5).map((t) => <span class="chip">{t}</span>)}
    </div>
    <div class="proj-links">
      {demo && <a href={demo} target="_blank" rel="noopener" class="proj-link">在线演示 ↗</a>}
      {repo && <a href={repo} target="_blank" rel="noopener" class="proj-link">源码 ↗</a>}
      <a href={href} class="proj-link primary">详情 →</a>
    </div>
  </div>
</article>

<style>
  .proj { display: flex; flex-direction: column; overflow: hidden; }
  .proj-cover { position: relative; display: block; aspect-ratio: 16 / 9; overflow: hidden; }
  .proj-cover img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .proj:hover .proj-cover img { transform: scale(1.06); }
  .proj-cover-fallback {
    width: 100%; height: 100%; display: grid; place-items: center;
    background: linear-gradient(135deg, rgba(34,211,238,0.16), rgba(168,85,247,0.18));
  }
  .proj-cover-fallback span { font-family: var(--font-mono); font-size: 2.4rem; font-weight: 700; color: rgba(255,255,255,0.7); }
  .proj-badge {
    position: absolute; top: 0.7rem; left: 0.7rem; font-family: var(--font-mono); font-size: 0.7rem;
    padding: 0.18rem 0.55rem; border-radius: 99px; color: #05060f; font-weight: 700;
    background: linear-gradient(110deg, var(--color-cyan), var(--color-violet));
  }
  .proj-body { padding: 1.1rem 1.2rem 1.3rem; display: flex; flex-direction: column; gap: 0.7rem; flex: 1; }
  .proj-title { font-size: 1.15rem; font-weight: 700; margin: 0; }
  .proj-title a { color: var(--color-ink); }
  .proj-title a:hover { color: var(--color-cyan); }
  .proj-desc { color: var(--color-ink-soft); font-size: 0.92rem; margin: 0; line-height: 1.65; }
  .proj-tech { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .proj-links { display: flex; gap: 1rem; margin-top: auto; padding-top: 0.4rem; font-size: 0.85rem; }
  .proj-link { color: var(--color-ink-dim); transition: color 0.2s; }
  .proj-link:hover { color: var(--color-cyan); }
  .proj-link.primary { color: var(--color-ink); margin-left: auto; }
</style>
