---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import Reveal from '@/components/Reveal.astro';
import TechStack from '@/components/TechStack.astro';
import { SITE, SOCIALS } from '@/consts';
import { withBase } from '@/utils/url';

// 经历时间线（替换为你自己的）
const timeline = [
  { year: '2026', title: 'AI Builder · 独立开发', desc: '专注 LLM 应用与 Agent 产品的设计与落地。' },
  { year: '2025', title: '开源与分享', desc: '开始系统地构建并开源 AI 工具，持续写作沉淀方法论。' },
  { year: '2024', title: '进入 AI 领域', desc: '从工程转向 AI，深入 RAG、Agent 与提示工程实践。' },
];

// 我能做什么
const skills = [
  { icon: '🤖', title: 'AI 应用开发', desc: '从 0 到 1 构建 LLM 驱动的产品，覆盖 RAG、Agent、工作流。' },
  { icon: '🧩', title: '系统设计', desc: '把模型能力工程化：缓存、降级、评测与可观测性。' },
  { icon: '✍️', title: '写作与分享', desc: '把实践沉淀为文章与知识库，帮助更多人构建。' },
];
---

<BaseLayout title="关于" description={SITE.description}>
  <div class="container-x">
    <PageHeader eyebrow="About" title="关于我" />

    <!-- 自我介绍 -->
    <Reveal>
      <section class="intro card">
        <div class="intro-avatar">
          <div class="avatar-ring breathe">
            <img src={withBase(SITE.avatar)} alt={SITE.name} />
          </div>
        </div>
        <div class="intro-text">
          <h2 class="intro-name">我是 <span class="text-gradient">{SITE.name}</span></h2>
          <p>一名 <strong>AI Builder</strong>。我热衷于把前沿的 AI 能力变成真正好用的产品 —— 让想法长出会思考的形态。</p>
          <p>我相信构建是最好的学习方式。这里记录我做过的项目、写下的思考，以及一路积累的知识。</p>
          <div class="intro-socials">
            {SOCIALS.map((s) => (
              <a href={s.href} target={s.href.startsWith('http') ? '_blank' : undefined} rel="noopener" class="chip">{s.label}</a>
            ))}
          </div>
        </div>
      </section>
    </Reveal>

    <!-- 我能做什么 -->
    <section class="block">
      <Reveal><h2 class="block-title">我能做什么</h2></Reveal>
      <div class="skills">
        {skills.map((s, i) => (
          <Reveal delay={i * 90}>
            <div class="card skill">
              <span class="skill-icon">{s.icon}</span>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          </Reveal>
        ))}
      </div>
    </section>

    <!-- 时间线 -->
    <section class="block">
      <Reveal><h2 class="block-title">经历</h2></Reveal>
      <div class="timeline">
        {timeline.map((t, i) => (
          <Reveal delay={i * 90}>
            <div class="tl-item">
              <span class="tl-year">{t.year}</span>
              <div class="tl-body card">
                <h3>{t.title}</h3>
                <p>{t.desc}</p>
              </div>
            </div>
          </Reveal>
        ))}
      </div>
    </section>

    <!-- 技术栈 -->
    <section class="block">
      <Reveal><h2 class="block-title">技术栈</h2></Reveal>
      <Reveal delay={100}><TechStack /></Reveal>
    </section>
  </div>
</BaseLayout>

<style>
  .intro { display: flex; gap: 2rem; align-items: center; padding: 2rem; }
  .intro-avatar { flex-shrink: 0; }
  .avatar-ring { width: 150px; height: 150px; border-radius: 50%; padding: 5px; background: conic-gradient(from 0deg, var(--color-cyan), var(--color-violet), var(--color-blue), var(--color-cyan)); }
  .avatar-ring img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; border: 4px solid var(--color-space-950); background: var(--color-space-800); }
  .intro-name { font-size: 1.6rem; margin: 0 0 0.8rem; }
  .intro-text p { color: var(--color-ink-soft); line-height: 1.8; margin: 0.5rem 0; }
  .intro-socials { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem; }
  .intro-socials .chip { text-decoration: none; }
  .intro-socials .chip:hover { color: var(--color-cyan); border-color: rgba(34,211,238,0.5); }

  .block { margin-top: 4rem; }
  .block-title { font-size: 1.4rem; font-weight: 700; margin: 0 0 1.4rem; }

  .skills { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem; }
  .skill { padding: 1.5rem; }
  .skill-icon { font-size: 1.8rem; }
  .skill h3 { margin: 0.7rem 0 0.5rem; font-size: 1.1rem; }
  .skill p { color: var(--color-ink-soft); font-size: 0.92rem; line-height: 1.7; margin: 0; }

  .timeline { display: flex; flex-direction: column; gap: 1rem; }
  .tl-item { display: grid; grid-template-columns: 5rem 1fr; gap: 1rem; align-items: start; }
  .tl-year { font-family: var(--font-mono); font-size: 1.1rem; font-weight: 700; color: var(--color-cyan); padding-top: 1.2rem; }
  .tl-body { padding: 1.1rem 1.3rem; }
  .tl-body h3 { margin: 0 0 0.4rem; font-size: 1.05rem; }
  .tl-body p { color: var(--color-ink-soft); font-size: 0.92rem; line-height: 1.7; margin: 0; }

  @media (max-width: 720px) {
    .intro { flex-direction: column; text-align: center; }
    .intro-socials { justify-content: center; }
    .skills { grid-template-columns: 1fr; }
  }
</style>
